      { "name": "creator",   "type": "address", "internalType": "address" },
      { "name": "startTime", "type": "uint256", "internalType": "uint256" }
    ],
    "outputs": [
      { "name": "token", "type": "address", "internalType": "address" },
      { "name": "curve", "type": "address", "internalType": "address" }
