# Lick.fun Indexer — Environment Variables
# Copy to .env and fill in values.

# ── RPC ──────────────────────────────────────────────────────
# Monad mainnet RPC (chain_id = 143) — use a dedicated provider (e.g. Alchemy, BlastAPI)
# config.yaml reads this as ${RPC_URL}
RPC_URL=https://monad-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# ── Envio Hosted Service ──────────────────────────────────────
# Obtain from https://envio.dev after creating a project
ENVIO_API_TOKEN=

# ── Local Dev ────────────────────────────────────────────────
# PostgreSQL URL used by `envio dev` (defaults in docker-compose)
POSTGRES_URL=postgresql://postgres:testing@localhost:5432/envio-dev
