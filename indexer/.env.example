# Lick.fun Indexer — Environment Variables
# Copy to .env and fill in values after Stage 6 deployment.

# ── RPC ──────────────────────────────────────────────────────
# Monad testnet public RPC (chain_id = 10143)
RPC_URL=https://testnet-rpc.monad.xyz

# ── Contract Addresses (fill after Stage 6 deploy) ───────────
# Factory contract address on Monad testnet
FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# ── Envio Hosted Service (fill after Stage 6) ────────────────
# Obtain from https://envio.dev after creating a project
ENVIO_API_TOKEN=

# ── Local Dev ────────────────────────────────────────────────
# PostgreSQL URL used by `envio dev` (defaults in docker-compose)
POSTGRES_URL=postgresql://postgres:testing@localhost:5432/envio-dev
