# Envio HyperIndex GraphQL endpoint
# Defaults to local development endpoint
# For production, use: https://indexer.dev.hyperindex.xyz/{deployment-hash}/v1/graphql
# Example: https://indexer.dev.hyperindex.xyz/4c6d1c8/v1/graphql
NEXT_PUBLIC_ENVIO_GRAPHQL_URL=http://localhost:8080/v1/graphql

# Monad RPC URLs
NEXT_PUBLIC_MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_MONAD_RPC=https://rpc.monad.xyz

# Private Monad RPC — server-side only (reserved for future use).
# The /api/trades/[curve] supplement fetches via Envio HyperSync now (see below),
# so this RPC URL is no longer required.
# MONAD_RPC_URL=

# Envio HyperSync API token — server-side only (used by /api/trades/[curve] to
# supplement the indexer with missed CurveBuy/CurveSell events). Create one at
# https://app.envio.dev/api-tokens (HyperSync now requires a token, otherwise
# the API returns "token is malformed" 401).
ENVIO_API_TOKEN=

# WalletConnect Project ID (required for RainbowKit)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Contract addresses (Monad testnet)
NEXT_PUBLIC_FACTORY_ADDRESS=
NEXT_PUBLIC_PREDICTION_MARKET_ADDRESS=
NEXT_PUBLIC_FEE_ROUTER_ADDRESS=
NEXT_PUBLIC_GRADUATION_POOL_ADDRESS=
NEXT_PUBLIC_VESTING_CONTROLLER_ADDRESS=

# Storj S3-compatible storage — server-side only (never expose to browser)
STORJ_ACCESS_KEY_ID=
STORJ_SECRET_ACCESS_KEY=
STORJ_ENDPOINT=
STORJ_BUCKET=

# Public base URL for serving images (no trailing slash)
NEXT_PUBLIC_STORAGE_BASE_URL=

# Canonical site URL — used in /api/token-metadata responses so aggregators
# get correct absolute URLs for token pages and the metadata list endpoint.
# No trailing slash. Example: https://lickfun.xyz
NEXT_PUBLIC_SITE_URL=https://lickfun.xyz

# ── Error monitoring (Sentry) — optional, no-op if unset ─────────────────────
# Create a free project at https://sentry.io, then copy its DSN here. Used by
# instrumentation-client.ts, src/sentry.server.config.ts, and
# src/sentry.edge.config.ts. Without this set, Sentry.init() is never called
# and there is zero behavior change.
NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=                        # optional server-only override, same value as above
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# Source-map upload (optional, CI/build-time only — makes Sentry stack traces
# readable). Leave unset for local dev; set these three in your Railway build
# environment if you want prettier stack traces in the Sentry dashboard.
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# ── Analytics (Plausible) — optional, no-op if unset ─────────────────────────
# Plausible is cookie-less and collects no personal data, so no
# cookie-consent banner is required for it specifically. Sign up at
# https://plausible.io (or self-host), add lickfun.xyz as a site, then set:
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Only needed if self-hosting Plausible instead of using plausible.io:
# NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=https://your-plausible-instance.example.com/js/script.js
