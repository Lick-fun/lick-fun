# Envio HyperIndex GraphQL endpoint
# Defaults to local development endpoint
# For production, use: https://indexer.dev.hyperindex.xyz/{deployment-hash}/v1/graphql
# Example: https://indexer.dev.hyperindex.xyz/4c6d1c8/v1/graphql
NEXT_PUBLIC_ENVIO_GRAPHQL_URL=http://localhost:8080/v1/graphql

# Monad RPC URLs
NEXT_PUBLIC_MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_MONAD_RPC=https://rpc.monad.xyz

# WalletConnect Project ID (required for RainbowKit)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Contract addresses (Monad testnet)
NEXT_PUBLIC_FACTORY_ADDRESS=
NEXT_PUBLIC_PREDICTION_MARKET_ADDRESS=
NEXT_PUBLIC_FEE_ROUTER_ADDRESS=
NEXT_PUBLIC_GRADUATION_POOL_ADDRESS=
NEXT_PUBLIC_VESTING_CONTROLLER_ADDRESS=

# Storj S3-compatible storage — server-side only (never expose to browser)
STORJ_ACCESS_KEY_ID=
STORJ_SECRET_ACCESS_KEY=
STORJ_ENDPOINT=
STORJ_BUCKET=

# Public base URL for serving images (no trailing slash)
NEXT_PUBLIC_STORAGE_BASE_URL=
