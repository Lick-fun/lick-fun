# Lick.fun — Root .gitignore (monorepo)

# Environment / secrets
.env
.env.*
!.env.example

# Node (frontend, indexer)
node_modules/
dist/
build/
.next/
.cache/
.turbo/

# TypeScript build cache
*.tsbuildinfo

# Envio HyperIndex generated
indexer/generated/
indexer/.env/
.envio-cloud/

# Duplicate/temp directories
lick-fun/

# OS files
.DS_Store
Thumbs.db

# Editor
.idea/
.vscode/*
!.vscode/extensions.json

# Foundry build artifacts
contracts/out/
contracts/cache/
contracts/broadcast/

# Foundry dependencies (installed via forge install / git submodules)
contracts/lib/

# Logs
*.log
npm-debug.log*

# Local RAG memory (MCP local-rag storage)
# Ignore everything in .memory/ except chat-history session notes (2026-*).
# Use .memory/* (not .memory/) so the negation pattern below can re-include
# specific files — git cannot re-include files under a fully-ignored directory.
.memory/*
# But keep chat-history memory docs tracked
!.memory/2026-*

# Anima design tool (contains local user paths)
.anima/
