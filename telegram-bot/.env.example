# ─── Telegram ───────────────────────────────────────────────────────────────────
# Bot token from @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram group chat ID where the bot operates and posts alerts.
# To find it: add the bot to the group, send /start, then visit
# https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates
# Look for the chat id (starts with "-").
TELEGRAM_GROUP_ID=

# ─── Lickfun Indexer (GraphQL) ──────────────────────────────────────────────────
# Public Envio HyperIndex endpoint for the Lickfun indexer.
# Same URL the frontend uses (see frontend/.env.local → NEXT_PUBLIC_ENVIO_GRAPHQL_URL).
GRAPHQL_URL=https://indexer.dev.hyperindex.xyz/a49668b/v1/graphql

# ─── Founder Coin ──────────────────────────────────────────────────────────────
# Lickfun founder token address (lowercase). Full alerts are sent for this token.
FOUNDER_TOKEN_ADDRESS=0x0236787a1baaeed46a123fa264a2355eed11d151

# Founder coin image URL — used as the bot's profile picture (set manually via
# BotFather /setuserpic) AND attached to every founder-coin buy alert.
# This is the Storj URL already registered in frontend/src/data/token-metadata.json.
FOUNDER_IMAGE_URL=https://link.storjshare.io/s/jvqgktahde346s3s65orx4mmtk4a/lickfun/tokens/lickfun-1782537764601.png?wrap=0

# ─── Branding ──────────────────────────────────────────────────────────────────
SITE_URL=https://lickfun.xyz
EXPLORER_URL=https://monadexplorer.com

# ─── Behaviour ─────────────────────────────────────────────────────────────────
# How often (ms) the watcher polls the GraphQL endpoint for new trades.
POLL_INTERVAL_MS=4000

# Minimum MON spent on a buy before the bot posts an alert (in MON, not wei).
# 0 = alert on every buy. 1 = ignore buys under 1 MON.
MIN_BUY_ALERT_MON=0

# Auto-kick users who don't tap the "I'm human" button within this many seconds.
VERIFY_TIMEOUT_SECONDS=300

# Set to "true" to also post alerts for non-founder Lickfun tokens (lighter format).
ENABLE_OTHER_TOKEN_ALERTS=true

# Set to "true" to also post alerts for sells (not just buys).
ENABLE_SELL_ALERTS=false
