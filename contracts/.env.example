# Lick.fun — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it contains your private key.

# Your wallet private key (WITHOUT 0x prefix is fine for forge).
# Generate a dedicated deployer wallet; do NOT reuse your main wallet.
PRIVATE_KEY=your_private_key_here

# Monad testnet RPC URL (chain_id = 10143)
# Official Monad testnet endpoint:
RPC_URL=https://testnet-rpc.monad.xyz

# Optional: Etherscan/Blockscout explorer API key for verification
# (Monad testnet explorer: https://testnet.monadexplorer.com)
ETHERSCAN_API_KEY=