# Lick.fun — Graduation Keeper
# Copy this file to script/.env and fill in your values.
# NEVER commit script/.env — it contains a private key.

# ── Required ──────────────────────────────────────────────────────────────────

# Monad mainnet RPC URL
KEEPER_RPC_URL=https://rpc.monad.xyz

# Funded keeper wallet private key (needs MON for gas — each migration ~0.5 MON)
# Use a dedicated throwaway wallet, NOT your main deployer or Safe key.
KEEPER_PRIVATE_KEY=0x_your_keeper_wallet_private_key_here

# Mainnet contract addresses (from DeployMainnet.s.sol output)
GRADUATION_ROUTER_ADDR=0xb2Dc164Ac4eCDDA7Ea2D4115bC122463c65460b2
FACTORY_ADDR=0x9845c5625d9f9C48e17956940485aAAAD168aA10

# ── Optional ──────────────────────────────────────────────────────────────────

# Block to start scanning from (defaults to 0 — use deploy block to skip history)
START_BLOCK=83961211

# How often to poll for new graduation events in milliseconds (default: 6000)
# POLL_INTERVAL_MS=6000
